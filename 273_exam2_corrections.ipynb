    "class Cpandh(param.Parameterized):\n",
    "    coef = param.Array(np.array([3.346E-02, 6.880E-06, 7.604E-09, -3.593E-12]), doc = 'array of heat capacity coefficients, default is water vapor')\n",
    "    T1 = param.Number(doc='initial temp')\n",
    "    T2 = param.Number(doc = 'final temp')\n",
    "    Hvap = param.Number(40.656, doc = 'h of vaporization, kJ/mol, default is water')\n",
    "    Hm = param.Number(6.0095, doc = 'h of melting/heat of fusion, kJ/mol, default is water')\n",
    "    \n",
    "    def heatcapacity(self, coef, T1, T2): \n",
    "        '''[=] kJ/mol'''\n",
    "        eq = self.coef[0] + self.coef[1]*T + self.coef[2]*T**2 + self.coef[3]*T**3\n",
    "        return eq\n",
    "    \n",
    "    def h_deltaT(self): #kJ/mol\n",
    "        '''[=] kJ/mol'''\n",
    "        eq = self.coef[0]*(self.T2-self.T1)+(self.coef[1]/2)*(self.T2**2-self.T1**2)+(self.coef[2]/3)*((self.T2**3-self.T1**3)) +(self.coef[3]/4)*((self.T2**4-self.T1**4))\n",
    "        return eq\n",
    "    \n",
    "    def h_vap(self):\n",
    "        '''enthalpy of vaporization'''\n",
    "        return self.Hvap\n",
    "    \n",
    "    def h_cond(self):\n",
    "        '''enthalpy of condensation'''\n",
    "        return -self.Hvap\n",
    "    \n",
    "    def h_melt(self):\n",
    "        '''enthalpy of melting'''\n",
    "        return self.Hm"
   ]
  },
