    "#Antoine's equation\n",
    "\n",
    "def Psat(x, T):\n",
    "    '''Psat has units of mmHg, T has units of C'''\n",
    "    a, b, c = x\n",
    "    eq = 10**(a - b/(c+T))\n",
    "    return eq\n",
    "\n",
    "hexane = [6.86839, 1151.401, 228.477]\n",
    "\n",
    "print(Psat(hexane, 41.8)/760)"
