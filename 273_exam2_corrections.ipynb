    "Tc = 469.8  # K\n",
    "Pc = 33.3  # atm\n",
    "\n",
    "R = 0.0821  # L*atm/(mol*K)\n",
    "MW = 72.15  # g/mol\n",
    "V = 1.5 #L\n",
    "P = 2  # atm\n",
    "T = 45 + 273.15  # K\n",
    "\n",
    "def f(n):\n",
    "    a = (0.43 * (R**2) * (Tc**2.4)) / Pc\n",
    "    b = (0.08 * R * Tc) / Pc\n",
    "    eq = (R * T) / (V/n - b) - a/(T**0.4 * (V/n)**2) - P\n",
    "    return eq\n",
    "\n",
    "n_guess = 1000\n",
    "n_solution = fsolve(f, n_guess)\n",
    "m = n_solution * MW\n",
    "\n",
    "print(f'Moles: {n_solution[0]:.4f} mol')\n",
    "print('Mass:',m/1000, 'kg')\n"
   ]
