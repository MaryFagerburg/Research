    "#fsolve\n",
    "\n",
    "Psatb = Psat(benzene, 46)/760\n",
    "Psateb = Psat( ethylbenzene, 46)/760\n",
    "\n",
    "def h(b):\n",
    "    P, xb = b\n",
    "    eq1 = xb*Psatb - 0.42*P\n",
    "    eq2 = (1-xb)*Psateb - 0.58*P\n",
    "    return (eq1,eq2)\n",
    "\n",
    "guess1 = [1.5, 0.5]\n",
    "fsolve(h,guess1)\n",
    "ans = fsolve(h,guess1)\n",
    "\n",
    "print(ans)"
